<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="specification" class="car.autowiring.constructure.Specification">
        <property name="make" value=" suv by  Constructure"/>
        <property name="model" value="corolla by  Constructure"/>
    </bean>

    <bean id="mycar" class="car.autowiring.constructure.Car" autowire="constructor"/>
</beans>